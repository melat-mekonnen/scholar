{
  "name": "scholar-backend",
  "version": "1.0.0",
  "description": "Backend API for scholarship dashboard (Next.js frontend) with email/password and Google auth using Neon Postgres.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate:application-url": "node scripts/add-application-url-column.js",
    "seed:daad-url": "node scripts/set-daad-application-url.js",
    "migrate:bookmarks": "node scripts/migrate-bookmarks-table.js",
    "migrate:documents": "node scripts/migrate-documents-table.js",
    "migrate:community": "node scripts/migrate-community-tables.js",
    "migrate:scholarship-sources": "node scripts/migrate-scholarship-sources.js"
  },
  "keywords": [
    "express",
    "neon",
    "postgres",
    "jwt",
    "google-oauth"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "google-auth-library": "^9.14.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
